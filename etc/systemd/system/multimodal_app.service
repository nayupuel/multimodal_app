[Unit]
Description=Gunicorn instance for multimodal_app
After=network.target

[Service]
User=ec2-user
Group=nginx
WorkingDirectory=/home/ec2-user/multimodal_app_deploy/src # 변경된 Gunicorn 실행 디렉토리
Environment="PATH=/home/ec2-user/multimodal_app_deploy/src/venv/bin" # 변경된 가상 환경 경로
ExecStart=/home/ec2-user/multimodal_app_deploy/src/venv/bin/gunicorn --workers 3 --bind unix:/home/ec2-user/multimodal_app_deploy/src/multimodal_app.sock run:app
# run:app: run.py 파일 내의 Flask 앱 인스턴스 이름
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target